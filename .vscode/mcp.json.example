// Template for VS Code MCP config. Copy to .vscode/mcp.json (gitignored).
// Uses hosted GitHub MCP, optional graphify, and the workspace-local
// youtube-transcript server. See docs/mcp-setup.md.
{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    // graphify serves graphify-out/graph.json over stdio. Multi-repo: set
    // "args": ["repos/<name>/graphify-out/graph.json"] to pick a specific graph.
    "graphify": {
      "type": "stdio",
      "command": "graphify-mcp",
      "args": []
    },
    "youtube-transcript": {
      "type": "stdio",
      "command": "${WORKSPACE_ROOT}/scripts/mcp/youtube-transcript.sh"
    }
  }
}
