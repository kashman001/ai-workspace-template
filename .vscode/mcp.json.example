// Template for VS Code MCP config. Copy to .vscode/mcp.json (gitignored).
// Uses the hosted GitHub MCP server; export GITHUB_PERSONAL_ACCESS_TOKEN before
// launching (e.g. GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token)). See docs/mcp-setup.md.
{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
