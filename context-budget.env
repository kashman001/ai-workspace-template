# Context-budget thresholds (non-secret, checked in — see docs/context-budget.md).
# The "dumb zone": LLM quality degrades past ~150K context tokens regardless of
# advertised window size. Raise in one place as models improve. STOP must stay
# below the runtime's auto-compact trigger (150K < Claude Code's ~200K) or
# compaction fires before the deliberate rollover gets its chance.
CONTEXT_DUMB_ZONE_TOKENS=150000
CONTEXT_DUMB_ZONE_WARN_TOKENS=120000
