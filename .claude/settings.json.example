{
  "_comment": "Starter Claude Code config. Copy to .claude/settings.json (gitignored) and tailor; permissions may instead go in .claude/settings.local.json. Permissions are a personal trust decision — keep both files out of git. The hooks block wires context-budget session registration (SessionStart) and the WARN/STOP check (PostToolUse) — see docs/context-budget.md. See docs/workspace-structure.md -> '.claude/ — Claude Code (Project-Level)'.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "t=$(jq -r '.transcript_path // empty' 2>/dev/null); \"$CLAUDE_PROJECT_DIR\"/scripts/context-budget.sh register --runtime claude ${t:+--transcript \"$t\"} || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/context-budget-claude-hook.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh auth status)",
      "WebSearch"
    ]
  },
  "enabledMcpjsonServers": [
    "github"
  ]
}
