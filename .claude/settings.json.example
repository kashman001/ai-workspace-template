{
  "_comment": "Starter Claude Code config. Copy to .claude/settings.json (gitignored) and tailor; permissions may instead go in .claude/settings.local.json. Permissions are a personal trust decision — keep both files out of git. The hooks block wires the context-budget WARN/STOP hook (see docs/context-budget.md). See docs/workspace-structure.md -> '.claude/ — Claude Code (Project-Level)'.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/context-budget-claude-hook.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh auth status)",
      "WebSearch"
    ]
  },
  "enabledMcpjsonServers": [
    "github"
  ]
}
